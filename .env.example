# Kopiere diese Datei nach .env und fülle die Werte aus:
#   cp .env.example .env

# Domain (ohne https://)
APP_DOMAIN=haushalt.example.com

# Datenbank
DB_NAME=household
DB_USER=household
DB_PASSWORD=change-me

# JWT – mind. 32 zufällige Zeichen, z.B.:
#   openssl rand -base64 32
JWT_SECRET=change-me-min-32-chars-long-secret-here
